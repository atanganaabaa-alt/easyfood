# ============================================================
# EasyFood - fichiers ignorés par git
# ============================================================

# Dépendances (réinstallables via npm install)
node_modules/
backend/node_modules/
frontend/node_modules/
.pnp
.pnp.js

# Variables d'environnement (SECRETS : ne jamais committer)
.env
.env.local
.env.*.local
backend/.env

# Build de production du frontend
frontend/build/
/build/

# Fichiers importés par les utilisateurs (on garde le dossier, pas son contenu)
backend/uploads/*
!backend/uploads/.gitkeep

# Tests / couverture
/coverage

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Fichiers système / éditeur
.DS_Store
.vscode/
.sixth/
*.swp
