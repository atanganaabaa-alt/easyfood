# ============================================================
# EasyFood - Exemple de configuration backend
# Copiez ce fichier en ".env" puis remplissez vos vraies valeurs :
#   cp .env.example .env
# ============================================================

# Port du serveur Express
PORT=5000

# Connexion PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=easyfood
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe_postgres

# Clé secrète pour signer les tokens JWT (mettez une longue chaîne aléatoire)
JWT_SECRET=changez_moi_par_une_chaine_secrete_aleatoire

# ============================================================
# Paiement Mobile Money
# PAIEMENT_MODE = simulation (défaut, dev) | reel (appelle les vraies API)
# ============================================================
PAIEMENT_MODE=simulation

# --- MTN MoMo Collections (https://momodeveloper.mtn.com) ---
MTN_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_SUBSCRIPTION_KEY=
MTN_API_USER=
MTN_API_KEY=
MTN_TARGET_ENV=sandbox
MTN_CURRENCY=EUR

# --- Orange Money Web Payment (https://developer.orange.com) ---
ORANGE_BASE_URL=https://api.orange.com
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=
ORANGE_MERCHANT_KEY=
ORANGE_COUNTRY=cm
ORANGE_CURRENCY=XAF
ORANGE_RETURN_URL=https://votre-domaine.cm/paiement/retour
ORANGE_CANCEL_URL=https://votre-domaine.cm/paiement/annule
ORANGE_NOTIF_URL=https://votre-domaine.cm/api/paiement/webhook
